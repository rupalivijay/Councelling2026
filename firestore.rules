rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isCounselor() {
      return isSignedIn() && exists(/databases/$(database)/documents/counselors/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'rupalilamkhade1997@gmail.com'
      );
    }

    // --- Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) 
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 100
        && (data.get('displayName', '') is string && data.displayName.size() <= 100)
        && (data.get('role', 'student') in ['student', 'counselor'])
        && (data.get('category', 'General') in ['General', 'OBC', 'SC', 'ST', 'EWS'])
        && (data.get('domicile', '') is string && data.domicile.size() <= 50)
        && (data.get('savedColleges', []) is list && data.get('savedColleges', []).size() <= 50)
        && (data.get('notificationSettings', {}) is map)
        && (data.get('isPaid', false) is bool);
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['name', 'status'])
        && data.name is string && data.name.size() <= 100
        && data.status in ['Pending', 'Uploaded', 'Verified', 'Needs Attention']
        && (data.get('url', '') is string && data.url.size() <= 500)
        && (data.get('feedback', '') is string && data.feedback.size() <= 500);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'timestamp', 'role', 'senderName'])
        && data.text is string && data.text.size() <= 1000
        && data.senderId == request.auth.uid
        && data.role in ['student', 'counselor']
        && data.senderName is string && data.senderName.size() <= 100;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['studentId', 'date', 'time', 'status'])
        && data.studentId == request.auth.uid
        && data.date is string && data.date.size() <= 20
        && data.time is string && data.time.size() <= 20
        && data.status in ['pending', 'scheduled', 'completed', 'cancelled'];
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.phone is string && data.phone.size() <= 20
        && (data.get('subject', '') is string && data.subject.size() <= 200)
        && (data.get('status', 'new') in ['new', 'contacted', 'converted', 'ignored'])
        && data.createdAt == request.time;
    }

    // --- Match Rules ---

    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(incoming());
      allow read, write: if isValidId(leadId) && isAdmin();
    }

    match /users/{userId} {
      allow get: if isValidId(userId) && (isOwner(userId) || isCounselor() || isAdmin());
      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming());
      allow update: if isValidId(userId) && ((isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'category', 'domicile', 'savedColleges', 'notificationSettings'])
      )) || ((isAdmin() || isCounselor()) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['isPaid', 'role', 'displayName', 'category', 'domicile', 'savedColleges', 'notificationSettings'])
      )) || isAdmin());
      
      match /documents/{docId} {
        allow list, get: if isValidId(docId) && (isOwner(userId) || isCounselor() || isAdmin());
        allow create: if isValidId(docId) && isOwner(userId) && isValidDocument(incoming());
        allow update: if isValidId(docId) && ((isOwner(userId) && isValidDocument(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['url', 'status']) && incoming().status == 'Uploaded'
        )) || (isCounselor() && isValidDocument(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'feedback'])
        )) || isAdmin());
      }

      match /messages/{msgId} {
        allow list, get: if isValidId(msgId) && (isOwner(userId) || isCounselor() || isAdmin());
        allow create: if isValidId(msgId) && (isOwner(userId) || isCounselor()) && isValidMessage(incoming());
      }

      match /appointments/{appId} {
        allow list, get: if isValidId(appId) && (isOwner(userId) || isCounselor() || isAdmin());
        allow create: if isValidId(appId) && isOwner(userId) && isValidAppointment(incoming());
        allow update: if isValidId(appId) && ((isOwner(userId) && isValidAppointment(incoming()) && (
          existing().status != 'completed' && incoming().diff(existing()).affectedKeys().hasOnly(['date', 'time', 'status'])
        )) || (isCounselor() && isValidAppointment(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'meetingLink'])
        )) || isAdmin());
      }
    }

    match /colleges/{collegeId} {
      allow get: if isValidId(collegeId);
      allow list: if true;
      allow write: if isValidId(collegeId) && isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow list, get: if isValidId(testimonialId);
      allow write: if isValidId(testimonialId) && isAdmin();
    }

    match /notifications/{notifId} {
      allow list, get: if isValidId(notifId);
      allow write: if isValidId(notifId) && isAdmin();
    }

    match /counselors/{counselorId} {
      allow get: if isValidId(counselorId);
      allow write: if isValidId(counselorId) && isAdmin();
    }

    match /admins/{adminId} {
      allow read, write: if false; // Only manageable via Admin SDK/Console
    }
  }
}
